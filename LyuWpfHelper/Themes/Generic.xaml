<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:LyuWpfHelper.Converters"
    xmlns:controls="clr-namespace:LyuWpfHelper.Controls"
    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/LyuWpfHelper;component/Themes/TransitioningContentControl.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <converters:TransparentBrushFallbackConverter x:Key="TransparentBrushFallbackConverter" />

    <Style x:Key="LyuTitleBarButtonStyle" TargetType="{x:Type Button}">
        <Setter Property="Width" Value="46" />
        <Setter Property="Height" Value="{Binding TitleBarHeight, RelativeSource={RelativeSource AncestorType={x:Type controls:LyuWindow}}}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="#202020" />
        <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style
        x:Key="LyuTitleBarCloseButtonStyle"
        BasedOn="{StaticResource LyuTitleBarButtonStyle}"
        TargetType="{x:Type Button}" />

    <Style TargetType="{x:Type controls:LyuWindow}">
        <Setter Property="ResizeMode" Value="CanResize" />
        <Setter Property="AllowsTransparency" Value="False" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="#D6D6D6" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="TitleBarForeground" Value="Black" />
        <Setter Property="TitleBarHeight" Value="29" />
        <Setter Property="TitleBarBackground" Value="#F5F5F5" />
        <Setter Property="ShowIcon" Value="False" />
        <Setter Property="ShowTitle" Value="True" />
        <Setter Property="ShowMinButton" Value="True" />
        <Setter Property="ShowMaxButton" Value="True" />
        <Setter Property="ShowCloseButton" Value="True" />
        <Setter Property="TitleAlignment" Value="Left" />
        <Setter Property="TitleMargin" Value="10,0,0,0" />
        <Setter Property="CloseButtonBackground" Value="Transparent" />
        <Setter Property="CloseButtonForeground" Value="Black" />
        <Setter Property="CloseButtonHoverBackground" Value="#E81123" />
        <Setter Property="CloseButtonHoverForeground" Value="White" />
        <Setter Property="OtherButtonBackground" Value="Transparent" />
        <Setter Property="OtherButtonForeground" Value="Black" />
        <Setter Property="OtherButtonHoverBackground" Value="#E6E6E6" />
        <Setter Property="OtherButtonHoverForeground" Value="Black" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:LyuWindow}">
                    <Border
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">
                        <Grid Margin="{TemplateBinding Padding}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid
                                x:Name="PART_TitleBar"
                                Grid.Row="0"
                                Height="{TemplateBinding TitleBarHeight}"
                                Background="{TemplateBinding TitleBarBackground}"
                                TextElement.Foreground="{TemplateBinding TitleBarForeground}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Button
                                        x:Name="PART_IconButton"
                                        Grid.Column="0"
                                        Margin="14,0,0,0"
                                        VerticalAlignment="Center"
                                        shell:WindowChrome.IsHitTestVisibleInChrome="True"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Command="{x:Static SystemCommands.ShowSystemMenuCommand}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <ContentPresenter />
                                            </ControlTemplate>
                                        </Button.Template>
                                        <Image
                                            Width="16"
                                            Height="16"
                                            IsHitTestVisible="False"
                                            Source="{TemplateBinding Icon}" />
                                    </Button>

                                    <TextBlock
                                        x:Name="PART_TitleText"
                                        Grid.Column="1"
                                        Margin="{TemplateBinding TitleMargin}"
                                        HorizontalAlignment="{TemplateBinding TitleAlignment}"
                                        VerticalAlignment="Center"
                                        Text="{TemplateBinding Title}" />

                                    <ContentPresenter
                                        x:Name="PART_TitleContentPresenter"
                                        Grid.Column="2"
                                        Margin="10,0,0,0"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Center"
                                        shell:WindowChrome.IsHitTestVisibleInChrome="True"
                                        Content="{TemplateBinding TitleBarLeftContent}" />
                                </Grid>

                                <Border
                                    Grid.Column="1"
                                    Margin="0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Stretch">
                                    <Border.Background>
                                        <MultiBinding Converter="{StaticResource TransparentBrushFallbackConverter}">
                                            <Binding Path="TitleBarBackground" RelativeSource="{RelativeSource TemplatedParent}" />
                                            <Binding Path="Background" RelativeSource="{RelativeSource TemplatedParent}" />
                                        </MultiBinding>
                                    </Border.Background>

                                    <ContentPresenter
                                        x:Name="PART_TitleRightContentPresenter"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        shell:WindowChrome.IsHitTestVisibleInChrome="True"
                                        Content="{TemplateBinding TitleBarRightContent}" />
                                </Border>

                                <StackPanel
                                    x:Name="PART_ButtonPanel"
                                    Grid.Column="2"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Stretch"
                                    shell:WindowChrome.IsHitTestVisibleInChrome="True"
                                    Orientation="Horizontal"
                                    UseLayoutRounding="True">
                                    <StackPanel.Background>
                                        <MultiBinding Converter="{StaticResource TransparentBrushFallbackConverter}">
                                            <Binding Path="TitleBarBackground" RelativeSource="{RelativeSource TemplatedParent}" />
                                            <Binding Path="Background" RelativeSource="{RelativeSource TemplatedParent}" />
                                        </MultiBinding>
                                    </StackPanel.Background>

                                    <Button
                                        x:Name="PART_MinimizeButton"
                                        Width="45"
                                        shell:WindowChrome.IsHitTestVisibleInChrome="True"
                                        Command="{x:Static SystemCommands.MinimizeWindowCommand}"
                                        CommandParameter="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                        Content="&#xE921;"
                                        Foreground="{TemplateBinding OtherButtonForeground}"
                                        Style="{StaticResource LyuTitleBarButtonStyle}">
                                        <Button.Background>
                                            <MultiBinding Converter="{StaticResource TransparentBrushFallbackConverter}">
                                                <Binding Path="OtherButtonBackground" RelativeSource="{RelativeSource TemplatedParent}" />
                                                <Binding Path="TitleBarBackground" RelativeSource="{RelativeSource TemplatedParent}" />
                                                <Binding Path="Background" RelativeSource="{RelativeSource TemplatedParent}" />
                                            </MultiBinding>
                                        </Button.Background>
                                    </Button>

                                    <Button
                                        x:Name="PART_MaximizeButton"
                                        shell:WindowChrome.IsHitTestVisibleInChrome="True"
                                        Command="{x:Static SystemCommands.MaximizeWindowCommand}"
                                        CommandParameter="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                        Content="&#xE922;"
                                        Foreground="{TemplateBinding OtherButtonForeground}"
                                        Style="{StaticResource LyuTitleBarButtonStyle}">
                                        <Button.Background>
                                            <MultiBinding Converter="{StaticResource TransparentBrushFallbackConverter}">
                                                <Binding Path="OtherButtonBackground" RelativeSource="{RelativeSource TemplatedParent}" />
                                                <Binding Path="TitleBarBackground" RelativeSource="{RelativeSource TemplatedParent}" />
                                                <Binding Path="Background" RelativeSource="{RelativeSource TemplatedParent}" />
                                            </MultiBinding>
                                        </Button.Background>
                                    </Button>

                                    <Button
                                        x:Name="PART_RestoreButton"
                                        shell:WindowChrome.IsHitTestVisibleInChrome="True"
                                        Command="{x:Static SystemCommands.RestoreWindowCommand}"
                                        CommandParameter="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                        Content="&#xE923;"
                                        Foreground="{TemplateBinding OtherButtonForeground}"
                                        Style="{StaticResource LyuTitleBarButtonStyle}"
                                        Visibility="Collapsed">
                                        <Button.Background>
                                            <MultiBinding Converter="{StaticResource TransparentBrushFallbackConverter}">
                                                <Binding Path="OtherButtonBackground" RelativeSource="{RelativeSource TemplatedParent}" />
                                                <Binding Path="TitleBarBackground" RelativeSource="{RelativeSource TemplatedParent}" />
                                                <Binding Path="Background" RelativeSource="{RelativeSource TemplatedParent}" />
                                            </MultiBinding>
                                        </Button.Background>
                                    </Button>

                                    <Button
                                        x:Name="PART_CloseButton"
                                        shell:WindowChrome.IsHitTestVisibleInChrome="True"
                                        Command="{x:Static SystemCommands.CloseWindowCommand}"
                                        CommandParameter="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                        Content="&#xE8BB;"
                                        Foreground="{TemplateBinding CloseButtonForeground}"
                                        Style="{StaticResource LyuTitleBarCloseButtonStyle}">
                                        <Button.Background>
                                            <MultiBinding Converter="{StaticResource TransparentBrushFallbackConverter}">
                                                <Binding Path="CloseButtonBackground" RelativeSource="{RelativeSource TemplatedParent}" />
                                                <Binding Path="TitleBarBackground" RelativeSource="{RelativeSource TemplatedParent}" />
                                                <Binding Path="Background" RelativeSource="{RelativeSource TemplatedParent}" />
                                            </MultiBinding>
                                        </Button.Background>
                                    </Button>
                                </StackPanel>
                            </Grid>

                            <AdornerDecorator Grid.Row="1">
                                <ContentPresenter />
                            </AdornerDecorator>
                        </Grid>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="WindowState" Value="Normal">
                            <Setter TargetName="PART_MaximizeButton" Property="Visibility" Value="Visible" />
                            <Setter TargetName="PART_RestoreButton" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="WindowState" Value="Maximized">
                            <Setter TargetName="PART_MaximizeButton" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="PART_RestoreButton" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="ResizeMode" Value="NoResize">
                            <Setter TargetName="PART_MinimizeButton" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="PART_MaximizeButton" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="PART_RestoreButton" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="ResizeMode" Value="CanMinimize">
                            <Setter TargetName="PART_MaximizeButton" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="PART_RestoreButton" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="Icon" Value="{x:Null}">
                            <Setter TargetName="PART_IconButton" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="ShowTitle" Value="False">
                            <Setter TargetName="PART_TitleText" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="ShowMinButton" Value="False">
                            <Setter TargetName="PART_MinimizeButton" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="ShowMaxButton" Value="False">
                            <Setter TargetName="PART_MaximizeButton" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="PART_RestoreButton" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="ShowCloseButton" Value="False">
                            <Setter TargetName="PART_CloseButton" Property="Visibility" Value="Collapsed" />
                        </Trigger>

                        <Trigger SourceName="PART_MinimizeButton" Property="IsMouseOver" Value="True">
                            <Setter TargetName="PART_MinimizeButton" Property="Background" Value="{Binding OtherButtonHoverBackground, RelativeSource={RelativeSource TemplatedParent}}" />
                            <Setter TargetName="PART_MinimizeButton" Property="Foreground" Value="{Binding OtherButtonHoverForeground, RelativeSource={RelativeSource TemplatedParent}}" />
                        </Trigger>
                        <Trigger SourceName="PART_MaximizeButton" Property="IsMouseOver" Value="True">
                            <Setter TargetName="PART_MaximizeButton" Property="Background" Value="{Binding OtherButtonHoverBackground, RelativeSource={RelativeSource TemplatedParent}}" />
                            <Setter TargetName="PART_MaximizeButton" Property="Foreground" Value="{Binding OtherButtonHoverForeground, RelativeSource={RelativeSource TemplatedParent}}" />
                        </Trigger>
                        <Trigger SourceName="PART_RestoreButton" Property="IsMouseOver" Value="True">
                            <Setter TargetName="PART_RestoreButton" Property="Background" Value="{Binding OtherButtonHoverBackground, RelativeSource={RelativeSource TemplatedParent}}" />
                            <Setter TargetName="PART_RestoreButton" Property="Foreground" Value="{Binding OtherButtonHoverForeground, RelativeSource={RelativeSource TemplatedParent}}" />
                        </Trigger>
                        <Trigger SourceName="PART_CloseButton" Property="IsMouseOver" Value="True">
                            <Setter TargetName="PART_CloseButton" Property="Background" Value="{Binding CloseButtonHoverBackground, RelativeSource={RelativeSource TemplatedParent}}" />
                            <Setter TargetName="PART_CloseButton" Property="Foreground" Value="{Binding CloseButtonHoverForeground, RelativeSource={RelativeSource TemplatedParent}}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type controls:NotificationControl}">
        <Setter Property="MinWidth" Value="320" />
        <Setter Property="MaxWidth" Value="400" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:NotificationControl}">
                    <Border
                        x:Name="PART_MainBorder"
                        Padding="0"
                        CornerRadius="8">
                        <Border.Effect>
                            <DropShadowEffect
                                x:Name="PART_Shadow"
                                BlurRadius="15"
                                Opacity="0.3"
                                ShadowDepth="3"
                                Color="#000000" />
                        </Border.Effect>
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="PART_Transform" Y="0" />
                        </Border.RenderTransform>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                            <GradientStop Offset="0" Color="#E3F2FD" />
                                            <GradientStop Offset="0.3" Color="White" />
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding NotificationType, RelativeSource={RelativeSource TemplatedParent}}" Value="Success">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                                    <GradientStop Offset="0" Color="#E8F5E9" />
                                                    <GradientStop Offset="0.3" Color="White" />
                                                </LinearGradientBrush>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding NotificationType, RelativeSource={RelativeSource TemplatedParent}}" Value="Warning">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                                    <GradientStop Offset="0" Color="#FFF3E0" />
                                                    <GradientStop Offset="0.3" Color="White" />
                                                </LinearGradientBrush>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding NotificationType, RelativeSource={RelativeSource TemplatedParent}}" Value="Error">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                                    <GradientStop Offset="0" Color="#FFEBEE" />
                                                    <GradientStop Offset="0.3" Color="White" />
                                                </LinearGradientBrush>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!--  Left accent bar  -->
                            <Border
                                x:Name="PART_AccentBar"
                                Grid.Column="0"
                                Width="4"
                                VerticalAlignment="Stretch"
                                CornerRadius="8,0,0,8">
                                <Border.RenderTransformOrigin>0.5,0</Border.RenderTransformOrigin>
                                <Border.RenderTransform>
                                    <ScaleTransform ScaleY="{Binding RemainingProgress, RelativeSource={RelativeSource TemplatedParent}}" />
                                </Border.RenderTransform>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#2196F3" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding NotificationType, RelativeSource={RelativeSource TemplatedParent}}" Value="Success">
                                                <Setter Property="Background" Value="#4CAF50" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding NotificationType, RelativeSource={RelativeSource TemplatedParent}}" Value="Warning">
                                                <Setter Property="Background" Value="#FF9800" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding NotificationType, RelativeSource={RelativeSource TemplatedParent}}" Value="Error">
                                                <Setter Property="Background" Value="#F44336" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>

                            <!--  Content area  -->
                            <Grid Grid.Column="1" Margin="18,16,18,16">

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!--  Icon with circular background  -->
                                <Border
                                    Grid.Column="0"
                                    Width="48"
                                    Height="48"
                                    Margin="0,0,16,0"
                                    VerticalAlignment="Top"
                                    CornerRadius="24">
                                    <Border.RenderTransform>
                                        <ScaleTransform x:Name="PART_IconScale" CenterX="24" CenterY="24" ScaleX="1" ScaleY="1" />
                                    </Border.RenderTransform>
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#262196F3" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding NotificationType, RelativeSource={RelativeSource TemplatedParent}}" Value="Success">
                                                    <Setter Property="Background" Value="#264CAF50" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding NotificationType, RelativeSource={RelativeSource TemplatedParent}}" Value="Warning">
                                                    <Setter Property="Background" Value="#26FF9800" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding NotificationType, RelativeSource={RelativeSource TemplatedParent}}" Value="Error">
                                                    <Setter Property="Background" Value="#26F44336" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>

                                    <Path
                                        Width="24"
                                        Height="24"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Stretch="Uniform">
                                        <Path.Style>
                                            <Style TargetType="Path">
                                                <Setter Property="Fill" Value="#2196F3" />
                                                <Setter Property="Data" Value="M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22A10,10 0 0,1 2,12A10,10 0 0,1 12,2M12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4M11,16.5L6.5,12L7.91,10.59L11,13.67L16.59,8.09L18,9.5L11,16.5Z" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding NotificationType, RelativeSource={RelativeSource TemplatedParent}}" Value="Success">
                                                        <Setter Property="Fill" Value="#4CAF50" />
                                                        <Setter Property="Data" Value="M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22A10,10 0 0,1 2,12A10,10 0 0,1 12,2M12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4M11,16.5L6.5,12L7.91,10.59L11,13.67L16.59,8.09L18,9.5L11,16.5Z" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding NotificationType, RelativeSource={RelativeSource TemplatedParent}}" Value="Warning">
                                                        <Setter Property="Fill" Value="#FF9800" />
                                                        <Setter Property="Data" Value="M13,14H11V10H13M13,18H11V16H13M1,21H23L12,2L1,21Z" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding NotificationType, RelativeSource={RelativeSource TemplatedParent}}" Value="Error">
                                                        <Setter Property="Fill" Value="#F44336" />
                                                        <Setter Property="Data" Value="M12,2C17.53,2 22,6.47 22,12C22,17.53 17.53,22 12,22C6.47,22 2,17.53 2,12C2,6.47 6.47,2 12,2M15.59,7L12,10.59L8.41,7L7,8.41L10.59,12L7,15.59L8.41,17L12,13.41L15.59,17L17,15.59L13.41,12L17,8.41L15.59,7Z" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Path.Style>
                                    </Path>
                                </Border>

                                <!--  Content  -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock
                                        FontSize="16"
                                        FontWeight="SemiBold"
                                        Foreground="#212121"
                                        LineHeight="22"
                                        Text="{TemplateBinding Title}"
                                        TextWrapping="Wrap">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Title, RelativeSource={RelativeSource TemplatedParent}}" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Title, RelativeSource={RelativeSource TemplatedParent}}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock
                                        Margin="0,6,0,0"
                                        FontSize="13"
                                        Foreground="#757575"
                                        LineHeight="20"
                                        Text="{TemplateBinding Message}"
                                        TextWrapping="Wrap" />
                                </StackPanel>

                                <!--  Close Button  -->
                                <Button
                                    x:Name="PART_CloseButton"
                                    Grid.Column="2"
                                    Width="24"
                                    Height="24"
                                    Margin="12,0,0,0"
                                    VerticalAlignment="Top"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand">
                                    <Button.RenderTransform>
                                        <TransformGroup>
                                            <RotateTransform x:Name="PART_CloseRotate" Angle="0" CenterX="12" CenterY="12" />
                                            <ScaleTransform x:Name="PART_CloseScale" CenterX="12" CenterY="12" ScaleX="1" ScaleY="1" />
                                        </TransformGroup>
                                    </Button.RenderTransform>
                                    <Path
                                        Width="10"
                                        Height="10"
                                        Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z"
                                        Fill="#BDBDBD"
                                        Stretch="Uniform" />
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border
                                                x:Name="ButtonBorder"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="12">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ButtonBorder" Property="Background" Value="#1A000000" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                        </Grid>
                    </Border>

                    <ControlTemplate.Triggers>
                        <!--  Mouse hover animation  -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="PART_Shadow"
                                            Storyboard.TargetProperty="BlurRadius"
                                            To="20"
                                            Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation
                                            Storyboard.TargetName="PART_Shadow"
                                            Storyboard.TargetProperty="ShadowDepth"
                                            To="5"
                                            Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation
                                            Storyboard.TargetName="PART_Transform"
                                            Storyboard.TargetProperty="Y"
                                            To="-2"
                                            Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="PART_Shadow"
                                            Storyboard.TargetProperty="BlurRadius"
                                            To="15"
                                            Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation
                                            Storyboard.TargetName="PART_Shadow"
                                            Storyboard.TargetProperty="ShadowDepth"
                                            To="3"
                                            Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation
                                            Storyboard.TargetName="PART_Transform"
                                            Storyboard.TargetProperty="Y"
                                            To="0"
                                            Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>

                        <!--  Close button hover animation  -->
                        <Trigger SourceName="PART_CloseButton" Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="PART_CloseRotate"
                                            Storyboard.TargetProperty="Angle"
                                            To="90"
                                            Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="PART_CloseRotate"
                                            Storyboard.TargetProperty="Angle"
                                            To="0"
                                            Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>

                        <!--  Close button press animation  -->
                        <Trigger SourceName="PART_CloseButton" Property="IsPressed" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="PART_CloseScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="0.9"
                                            Duration="0:0:0.1" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="PART_CloseScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="0.9"
                                            Duration="0:0:0.1" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="PART_CloseScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="1"
                                            Duration="0:0:0.1" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="PART_CloseScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="1"
                                            Duration="0:0:0.1" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>

                        <!--  Icon load animation  -->
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation
                                        Storyboard.TargetName="PART_IconScale"
                                        Storyboard.TargetProperty="ScaleX"
                                        From="0.8"
                                        To="1"
                                        Duration="0:0:0.3">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut" />
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation
                                        Storyboard.TargetName="PART_IconScale"
                                        Storyboard.TargetProperty="ScaleY"
                                        From="0.8"
                                        To="1"
                                        Duration="0:0:0.3">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut" />
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

