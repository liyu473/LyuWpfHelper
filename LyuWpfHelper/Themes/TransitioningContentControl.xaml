<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:LyuWpfHelper.Controls">

    <!-- 内置动画资源 -->

    <!-- 1. Right2Left: 从右到左 -->
    <Storyboard x:Key="Right2LeftTransition" x:Shared="False">
        <DoubleAnimation From="50" To="0" Duration="0:0:0.4"
                         Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[3].(TranslateTransform.X)">
            <DoubleAnimation.EasingFunction>
                <CubicEase EasingMode="EaseOut"/>
            </DoubleAnimation.EasingFunction>
        </DoubleAnimation>
    </Storyboard>

    <!-- 2. Left2Right: 从左到右 -->
    <Storyboard x:Key="Left2RightTransition" x:Shared="False">
        <DoubleAnimation From="-50" To="0" Duration="0:0:0.4"
                         Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[3].(TranslateTransform.X)">
            <DoubleAnimation.EasingFunction>
                <CubicEase EasingMode="EaseOut"/>
            </DoubleAnimation.EasingFunction>
        </DoubleAnimation>
    </Storyboard>

    <!-- 3. Bottom2Top: 从下到上 -->
    <Storyboard x:Key="Bottom2TopTransition" x:Shared="False">
        <DoubleAnimation From="50" To="0" Duration="0:0:0.4"
                         Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[3].(TranslateTransform.Y)">
            <DoubleAnimation.EasingFunction>
                <CubicEase EasingMode="EaseOut"/>
            </DoubleAnimation.EasingFunction>
        </DoubleAnimation>
    </Storyboard>

    <!-- 4. Top2Bottom: 从上到下 -->
    <Storyboard x:Key="Top2BottomTransition" x:Shared="False">
        <DoubleAnimation From="-50" To="0" Duration="0:0:0.4"
                         Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[3].(TranslateTransform.Y)">
            <DoubleAnimation.EasingFunction>
                <CubicEase EasingMode="EaseOut"/>
            </DoubleAnimation.EasingFunction>
        </DoubleAnimation>
    </Storyboard>

    <!-- 5. Right2LeftWithFade: 从右到左 + 淡入 -->
    <Storyboard x:Key="Right2LeftWithFadeTransition" x:Shared="False">
        <DoubleAnimation From="0" To="1" Duration="0:0:0.4"
                         Storyboard.TargetProperty="(UIElement.Opacity)"/>
        <DoubleAnimation From="50" To="0" Duration="0:0:0.4"
                         Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[3].(TranslateTransform.X)">
            <DoubleAnimation.EasingFunction>
                <CubicEase EasingMode="EaseOut"/>
            </DoubleAnimation.EasingFunction>
        </DoubleAnimation>
    </Storyboard>

    <!-- 6. Left2RightWithFade: 从左到右 + 淡入 -->
    <Storyboard x:Key="Left2RightWithFadeTransition" x:Shared="False">
        <DoubleAnimation From="0" To="1" Duration="0:0:0.4"
                         Storyboard.TargetProperty="(UIElement.Opacity)"/>
        <DoubleAnimation From="-50" To="0" Duration="0:0:0.4"
                         Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[3].(TranslateTransform.X)">
            <DoubleAnimation.EasingFunction>
                <CubicEase EasingMode="EaseOut"/>
            </DoubleAnimation.EasingFunction>
        </DoubleAnimation>
    </Storyboard>

    <!-- 7. Bottom2TopWithFade: 从下到上 + 淡入 -->
    <Storyboard x:Key="Bottom2TopWithFadeTransition" x:Shared="False">
        <DoubleAnimation From="0" To="1" Duration="0:0:0.4"
                         Storyboard.TargetProperty="(UIElement.Opacity)"/>
        <DoubleAnimation From="50" To="0" Duration="0:0:0.4"
                         Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[3].(TranslateTransform.Y)">
            <DoubleAnimation.EasingFunction>
                <CubicEase EasingMode="EaseOut"/>
            </DoubleAnimation.EasingFunction>
        </DoubleAnimation>
    </Storyboard>

    <!-- 8. Top2BottomWithFade: 从上到下 + 淡入 -->
    <Storyboard x:Key="Top2BottomWithFadeTransition" x:Shared="False">
        <DoubleAnimation From="0" To="1" Duration="0:0:0.4"
                         Storyboard.TargetProperty="(UIElement.Opacity)"/>
        <DoubleAnimation From="-50" To="0" Duration="0:0:0.4"
                         Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[3].(TranslateTransform.Y)">
            <DoubleAnimation.EasingFunction>
                <CubicEase EasingMode="EaseOut"/>
            </DoubleAnimation.EasingFunction>
        </DoubleAnimation>
    </Storyboard>

    <!-- 9. Fade: 仅淡入 -->
    <Storyboard x:Key="FadeTransition" x:Shared="False">
        <DoubleAnimation From="0" To="1" Duration="0:0:0.4"
                         Storyboard.TargetProperty="(UIElement.Opacity)"/>
    </Storyboard>

    <!-- 控件样式 -->
    <Style TargetType="{x:Type controls:TransitioningContentControl}">
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:TransitioningContentControl}">
                    <ContentPresenter
                        x:Name="PART_ContentPresenter"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
