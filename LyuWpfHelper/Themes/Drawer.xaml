<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:LyuWpfHelper.Controls"
    xmlns:helpers="clr-namespace:LyuWpfHelper.Helpers"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!--  Drawer theme tokens (can be overridden by app resources)  -->
    <SolidColorBrush x:Key="LyuDrawer.Light.BackgroundBrush" Color="#FFF2F2F2" />
    <SolidColorBrush x:Key="LyuDrawer.Light.ForegroundBrush" Color="#FF101010" />
    <SolidColorBrush x:Key="LyuDrawer.Light.BorderBrush" Color="#22000000" />
    <SolidColorBrush x:Key="LyuDrawer.Light.HeaderBackgroundBrush" Color="#FFF2F2F2" />
    <SolidColorBrush x:Key="LyuDrawer.Light.HeaderForegroundBrush" Color="#FF101010" />
    <SolidColorBrush x:Key="LyuDrawer.Light.CloseIconBrush" Color="#FF616161" />
    <SolidColorBrush x:Key="LyuDrawer.Light.CloseHoverBackgroundBrush" Color="#14000000" />
    <SolidColorBrush x:Key="LyuDrawer.Light.CloseBorderBrush" Color="#FFACACAC" />
    <SolidColorBrush x:Key="LyuDrawer.Light.OverlayBrush" Color="#8C000000" />

    <SolidColorBrush x:Key="LyuDrawer.Dark.BackgroundBrush" Color="#FF242424" />
    <SolidColorBrush x:Key="LyuDrawer.Dark.ForegroundBrush" Color="#FFF2F2F2" />
    <SolidColorBrush x:Key="LyuDrawer.Dark.BorderBrush" Color="#30FFFFFF" />
    <SolidColorBrush x:Key="LyuDrawer.Dark.HeaderBackgroundBrush" Color="#FF2D2D2D" />
    <SolidColorBrush x:Key="LyuDrawer.Dark.HeaderForegroundBrush" Color="#FFF2F2F2" />
    <SolidColorBrush x:Key="LyuDrawer.Dark.CloseIconBrush" Color="#FFE4E4E4" />
    <SolidColorBrush x:Key="LyuDrawer.Dark.CloseHoverBackgroundBrush" Color="#26FFFFFF" />
    <SolidColorBrush x:Key="LyuDrawer.Dark.CloseBorderBrush" Color="#FF787878" />
    <SolidColorBrush x:Key="LyuDrawer.Dark.OverlayBrush" Color="#A6000000" />

    <!--  MahApps-like typography defaults  -->
    <sys:Double x:Key="LyuDrawer.Font.Size.Header">20</sys:Double>

    <Style TargetType="{x:Type controls:DrawersHost}">
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="Panel.ZIndex" Value="2147483647" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <Grid IsItemsHost="True" />
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:DrawersHost}">
                    <Grid ClipToBounds="True">
                        <Rectangle
                            x:Name="PART_OverlayLayer"
                            Fill="{DynamicResource LyuDrawer.Light.OverlayBrush}"
                            IsHitTestVisible="False"
                            Opacity="1"
                            Visibility="Hidden" />

                        <ItemsPresenter />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="LyuDrawer.HeaderCloseButtonStyle" TargetType="{x:Type Button}">
        <Setter Property="Width" Value="34" />
        <Setter Property="Height" Value="34" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{DynamicResource LyuDrawer.Light.CloseBorderBrush}" />
        <Setter Property="BorderThickness" Value="2" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Padding" Value="1" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Grid>
                        <Ellipse Fill="{TemplateBinding Background}" StrokeThickness="0" />
                        <Ellipse
                            x:Name="PART_ButtonFill"
                            Fill="{TemplateBinding Foreground}"
                            Opacity="0"
                            StrokeThickness="0" />
                        <Ellipse
                            x:Name="PART_ButtonStroke"
                            Opacity="0.7"
                            Stroke="{TemplateBinding BorderBrush}"
                            StrokeThickness="2" />
                        <ContentPresenter
                            Margin="{TemplateBinding Padding}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="PART_ButtonStroke" Property="Opacity" Value="1" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="PART_ButtonFill" Property="Opacity" Value="0.12" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="PART_ButtonFill" Property="Opacity" Value="0.22" />
                        </Trigger>
                        <DataTrigger Binding="{Binding ResolvedTheme, RelativeSource={RelativeSource AncestorType={x:Type controls:Drawer}}}" Value="{x:Static helpers:WindowThemeMode.Dark}">
                            <Setter Property="BorderBrush" Value="{DynamicResource LyuDrawer.Dark.CloseBorderBrush}" />
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type controls:Drawer}">
        <Setter Property="Background" Value="{DynamicResource LyuDrawer.Light.BackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource LyuDrawer.Light.ForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource LyuDrawer.Light.BorderBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="HeaderBackground" Value="{DynamicResource LyuDrawer.Light.HeaderBackgroundBrush}" />
        <Setter Property="HeaderForeground" Value="{DynamicResource LyuDrawer.Light.HeaderForegroundBrush}" />
        <Setter Property="CloseButtonForeground" Value="{DynamicResource LyuDrawer.Light.CloseIconBrush}" />
        <Setter Property="CloseButtonHoverBackground" Value="{DynamicResource LyuDrawer.Light.CloseHoverBackgroundBrush}" />
        <Setter Property="HeaderPadding" Value="10" />
        <Setter Property="ContentPadding" Value="18,12,18,18" />
        <Setter Property="ShowHeader" Value="True" />
        <Setter Property="ShowCloseButton" Value="True" />
        <Setter Property="TitleVisibility" Value="Visible" />
        <Setter Property="CloseButtonVisibility" Value="Visible" />
        <Setter Property="CloseButtonIsCancel" Value="False" />
        <Setter Property="AllowFocusElement" Value="True" />
        <Setter Property="IsAutoCloseEnabled" Value="False" />
        <Setter Property="AutoCloseInterval" Value="5000" />
        <Setter Property="ThemeMode" Value="{x:Static controls:DrawerThemeMode.Adapt}" />
        <Setter Property="OverlayBrush" Value="{DynamicResource LyuDrawer.Light.OverlayBrush}" />
        <Setter Property="OverlayOpacity" Value="1" />
        <Setter Property="Visibility" Value="Hidden" />
        <Setter Property="Focusable" Value="True" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="KeyboardNavigation.ControlTabNavigation" Value="Cycle" />
        <Setter Property="KeyboardNavigation.DirectionalNavigation" Value="Cycle" />
        <Setter Property="KeyboardNavigation.TabNavigation" Value="Cycle" />
        <Setter Property="Width" Value="360" />
        <Setter Property="MinWidth" Value="140" />
        <Setter Property="MinHeight" Value="140" />
        <Setter Property="Panel.ZIndex" Value="1" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:Drawer}">
                    <Border
                        x:Name="PART_Root"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}">
                        <Border.RenderTransform>
                            <TranslateTransform />
                        </Border.RenderTransform>
                        <DockPanel Focusable="False" LastChildFill="True">
                            <Border
                                x:Name="PART_HeaderContainer"
                                DockPanel.Dock="Top"
                                Background="{TemplateBinding HeaderBackground}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="0">
                                <DockPanel Margin="{TemplateBinding HeaderPadding}" LastChildFill="True">
                                    <Button
                                        x:Name="PART_CloseButton"
                                        DockPanel.Dock="Left"
                                        IsCancel="{TemplateBinding CloseButtonIsCancel}"
                                        Margin="2,4,2,2"
                                        Padding="2,0,0,0"
                                        Foreground="{TemplateBinding CloseButtonForeground}"
                                        Visibility="{TemplateBinding CloseButtonVisibility}"
                                        Style="{StaticResource LyuDrawer.HeaderCloseButtonStyle}">
                                        <Path
                                            x:Name="PART_CloseIcon"
                                            Width="13"
                                            Height="13"
                                            Data="M8.59,16.58L13.17,12L8.59,7.41L10,6L16,12L10,18L8.59,16.58Z"
                                            Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                                            Stretch="Uniform" />
                                    </Button>

                                    <ContentPresenter
                                        x:Name="PART_HeaderPresenter"
                                        Margin="15,0,0,0"
                                        VerticalAlignment="Center"
                                        ContentSource="Header"
                                        RecognizesAccessKey="True"
                                        Visibility="{TemplateBinding TitleVisibility}"
                                        TextElement.FontFamily="{TemplateBinding FontFamily}"
                                        TextElement.FontSize="{DynamicResource LyuDrawer.Font.Size.Header}"
                                        TextElement.FontWeight="{TemplateBinding FontWeight}"
                                        TextElement.Foreground="{TemplateBinding HeaderForeground}" />
                                </DockPanel>
                            </Border>

                            <Border
                                x:Name="PART_ContentContainer"
                                DockPanel.Dock="Bottom"
                                Padding="{TemplateBinding ContentPadding}">
                                <ContentPresenter
                                    x:Name="PART_ContentHost"
                                    ContentSource="Content"
                                    ContentTemplate="{TemplateBinding ContentTemplate}"
                                    ContentTemplateSelector="{TemplateBinding ContentTemplateSelector}" />
                            </Border>
                        </DockPanel>
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup>
                                <VisualState x:Name="Default" />
                                <VisualState x:Name="Hide">
                                    <Storyboard x:Name="HideStoryboard">
                                        <DoubleAnimationUsingKeyFrames
                                            Storyboard.TargetName="PART_Root"
                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)">
                                            <SplineDoubleKeyFrame
                                                x:Name="hideFrame"
                                                KeySpline="0.25,1,0.05,1"
                                                KeyTime="0:0:0.75"
                                                Value="0" />
                                        </DoubleAnimationUsingKeyFrames>
                                        <DoubleAnimationUsingKeyFrames
                                            Storyboard.TargetName="PART_Root"
                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)">
                                            <SplineDoubleKeyFrame
                                                x:Name="hideFrameY"
                                                KeySpline="0.25,1,0.05,1"
                                                KeyTime="0:0:0.75"
                                                Value="0" />
                                        </DoubleAnimationUsingKeyFrames>
                                        <DoubleAnimationUsingKeyFrames
                                            Storyboard.TargetName="PART_Root"
                                            Storyboard.TargetProperty="(UIElement.Opacity)">
                                            <SplineDoubleKeyFrame
                                                x:Name="fadeOutFrame"
                                                KeySpline="0.25,1,0.05,1"
                                                KeyTime="0:0:0.75"
                                                Value="0" />
                                        </DoubleAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Show">
                                    <Storyboard x:Name="ShowStoryboard">
                                        <DoubleAnimationUsingKeyFrames
                                            Storyboard.TargetName="PART_Root"
                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)">
                                            <SplineDoubleKeyFrame
                                                x:Name="showFrame"
                                                KeySpline="0.25,1,0.05,1"
                                                KeyTime="0:0:0.75"
                                                Value="0" />
                                        </DoubleAnimationUsingKeyFrames>
                                        <DoubleAnimationUsingKeyFrames
                                            Storyboard.TargetName="PART_Root"
                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)">
                                            <SplineDoubleKeyFrame
                                                x:Name="showFrameY"
                                                KeySpline="0.25,1,0.05,1"
                                                KeyTime="0:0:0.75"
                                                Value="0" />
                                        </DoubleAnimationUsingKeyFrames>
                                        <DoubleAnimationUsingKeyFrames
                                            Storyboard.TargetName="PART_Root"
                                            Storyboard.TargetProperty="(UIElement.Opacity)">
                                            <SplineDoubleKeyFrame
                                                x:Name="fadeInFrame"
                                                KeySpline="0.25,1,0.05,1"
                                                KeyTime="0:0:0.75"
                                                Value="1" />
                                        </DoubleAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="HideDirect">
                                    <Storyboard>
                                        <DoubleAnimationUsingKeyFrames
                                            Storyboard.TargetName="PART_Root"
                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)">
                                            <SplineDoubleKeyFrame KeyTime="0:0:0" Value="0" />
                                        </DoubleAnimationUsingKeyFrames>
                                        <DoubleAnimationUsingKeyFrames
                                            Storyboard.TargetName="PART_Root"
                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)">
                                            <SplineDoubleKeyFrame KeyTime="0:0:0" Value="0" />
                                        </DoubleAnimationUsingKeyFrames>
                                        <DoubleAnimationUsingKeyFrames
                                            Storyboard.TargetName="PART_Root"
                                            Storyboard.TargetProperty="(UIElement.Opacity)">
                                            <SplineDoubleKeyFrame KeyTime="0:0:0" Value="0" />
                                        </DoubleAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="ShowDirect">
                                    <Storyboard>
                                        <DoubleAnimationUsingKeyFrames
                                            Storyboard.TargetName="PART_Root"
                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)">
                                            <SplineDoubleKeyFrame KeyTime="0:0:0" Value="0" />
                                        </DoubleAnimationUsingKeyFrames>
                                        <DoubleAnimationUsingKeyFrames
                                            Storyboard.TargetName="PART_Root"
                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)">
                                            <SplineDoubleKeyFrame KeyTime="0:0:0" Value="0" />
                                        </DoubleAnimationUsingKeyFrames>
                                        <DoubleAnimationUsingKeyFrames
                                            Storyboard.TargetName="PART_Root"
                                            Storyboard.TargetProperty="(UIElement.Opacity)">
                                            <SplineDoubleKeyFrame KeyTime="0:0:0" Value="1" />
                                        </DoubleAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="TitleVisibility" Value="Collapsed">
                            <Setter TargetName="PART_HeaderContainer" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="CloseButtonVisibility" Value="Collapsed" />
                                <Condition Property="TitleVisibility" Value="Collapsed" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="PART_HeaderContainer" Property="Visibility" Value="Collapsed" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="CloseButtonVisibility" Value="Hidden" />
                                <Condition Property="TitleVisibility" Value="Hidden" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="PART_HeaderContainer" Property="Visibility" Value="Collapsed" />
                        </MultiTrigger>
                        <Trigger Property="CloseButtonVisibility" Value="Collapsed">
                            <Setter TargetName="PART_HeaderPresenter" Property="Margin" Value="0" />
                        </Trigger>
                        <Trigger Property="Position" Value="{x:Static controls:DrawerPosition.Left}">
                            <Setter
                                TargetName="PART_CloseIcon"
                                Property="Data"
                                Value="M15.41,16.58L10.83,12L15.41,7.41L14,6L8,12L14,18L15.41,16.58Z" />
                            <Setter TargetName="PART_CloseButton" Property="DockPanel.Dock" Value="Right" />
                            <Setter TargetName="PART_CloseButton" Property="Padding" Value="0,0,2,0" />
                            <Setter TargetName="PART_HeaderPresenter" Property="Margin" Value="0,0,15,0" />
                        </Trigger>
                        <Trigger Property="Position" Value="{x:Static controls:DrawerPosition.Top}">
                            <Setter
                                TargetName="PART_CloseIcon"
                                Property="Data"
                                Value="M7.41,15.41L12,10.83L16.59,15.41L18,14L12,8L6,14L7.41,15.41Z" />
                            <Setter TargetName="PART_CloseButton" Property="Padding" Value="0,0,0,2" />
                            <Setter TargetName="PART_ContentContainer" Property="DockPanel.Dock" Value="Right" />
                            <Setter TargetName="PART_HeaderContainer" Property="DockPanel.Dock" Value="Left" />
                        </Trigger>
                        <Trigger Property="Position" Value="{x:Static controls:DrawerPosition.Bottom}">
                            <Setter
                                TargetName="PART_CloseIcon"
                                Property="Data"
                                Value="M7.41,8.58L12,13.17L16.59,8.58L18,10L12,16L6,10L7.41,8.58Z" />
                            <Setter TargetName="PART_CloseButton" Property="Padding" Value="0,2,0,0" />
                            <Setter TargetName="PART_ContentContainer" Property="DockPanel.Dock" Value="Right" />
                            <Setter TargetName="PART_HeaderContainer" Property="DockPanel.Dock" Value="Left" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="Position" Value="{x:Static controls:DrawerPosition.Left}">
                <Setter Property="HorizontalAlignment" Value="Left" />
                <Setter Property="VerticalAlignment" Value="Stretch" />
            </Trigger>
            <Trigger Property="Position" Value="{x:Static controls:DrawerPosition.Right}">
                <Setter Property="HorizontalAlignment" Value="Right" />
                <Setter Property="VerticalAlignment" Value="Stretch" />
            </Trigger>
            <Trigger Property="Position" Value="{x:Static controls:DrawerPosition.Top}">
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="VerticalAlignment" Value="Top" />
                <Setter Property="Height" Value="300" />
                <Setter Property="Width" Value="Auto" />
            </Trigger>
            <Trigger Property="Position" Value="{x:Static controls:DrawerPosition.Bottom}">
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="VerticalAlignment" Value="Bottom" />
                <Setter Property="Height" Value="300" />
                <Setter Property="Width" Value="Auto" />
            </Trigger>
            <Trigger Property="ResolvedTheme" Value="{x:Static helpers:WindowThemeMode.Dark}">
                <Setter Property="Background" Value="{DynamicResource LyuDrawer.Dark.BackgroundBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource LyuDrawer.Dark.ForegroundBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource LyuDrawer.Dark.BorderBrush}" />
                <Setter Property="HeaderBackground" Value="{DynamicResource LyuDrawer.Dark.HeaderBackgroundBrush}" />
                <Setter Property="HeaderForeground" Value="{DynamicResource LyuDrawer.Dark.HeaderForegroundBrush}" />
                <Setter Property="CloseButtonForeground" Value="{DynamicResource LyuDrawer.Dark.CloseIconBrush}" />
                <Setter Property="CloseButtonHoverBackground" Value="{DynamicResource LyuDrawer.Dark.CloseHoverBackgroundBrush}" />
                <Setter Property="OverlayBrush" Value="{DynamicResource LyuDrawer.Dark.OverlayBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
