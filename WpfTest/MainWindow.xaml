<lyu:LyuWindow
    x:Class="WpfTest.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ikw="http://schemas.inkore.net/lib/ui/wpf"
    xmlns:local="clr-namespace:WpfTest"
    xmlns:lyu="http://schemas.lyuwpfhelper.com/winfx/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    Title="MainWindow"
    Width="1200"
    Height="800"
    d:DataContext="{d:DesignInstance Type=local:MainViewModel}"
    lyu:LyuWindowHelper.FullScreenKey="F11"
    lyu:WindowBackdropHelper.Backdrop="Mica"
    Icon="/Asserts/logo.ico"
    TitleBarBackground="Transparent"
    TitleBarHeight="40"
    mc:Ignorable="d">
    <lyu:LyuWindow.TitleBarLeftContent>
        <DockPanel LastChildFill="False">
            <TextBlock
                VerticalAlignment="Center"
                FontSize="14"
                FontWeight="SemiBold"
                Foreground="#223046"
                Text="LyuWpfHelper 窗口测试" />
            <Button
                Margin="16,0,0,0"
                Click="TitleBarRefreshButton_Click"
                Content="通知按钮" />
            <Button
                Margin="8,0,0,0"
                Click="OpenBackdropTest_Click"
                Content="Backdrop测试" />
        </DockPanel>
    </lyu:LyuWindow.TitleBarLeftContent>

    <lyu:LyuWindow.TitleBarRightContent>
        <lyu:SimpleStackPanel
            Margin="8,0"
            Orientation="Horizontal"
            Spacing="8">
            <TextBlock VerticalAlignment="Center" Text="主题" />
            <ComboBox
                x:Name="MainThemeComboBox"
                Width="100"
                SelectedIndex="0"
                SelectionChanged="MainThemeComboBox_SelectionChanged">
                <ComboBoxItem Tag="FollowSystem">跟随系统</ComboBoxItem>
                <ComboBoxItem Tag="Light">浅色</ComboBoxItem>
                <ComboBoxItem Tag="Dark">深色</ComboBoxItem>
            </ComboBox>
            <Button
                Width="80"
                Click="SetMainDefault_Click"
                Content="Default" />
            <Button
                Width="80"
                Click="SetMainAcrylic_Click"
                Content="Acrylic" />
            <Button
                Width="80"
                Click="SetMainMica_Click"
                Content="Mica" />
            <Button
                Width="80"
                Click="SetMainTabbed_Click"
                Content="Tabbed" />
        </lyu:SimpleStackPanel>
    </lyu:LyuWindow.TitleBarRightContent>

    <Grid>
        <TabControl lyu:TabControlTransitionHelper.TransitionMode="Right2LeftWithFade" Style="{StaticResource TabControlPivotStyle}">
            <TabItem Header="SimpleStackPanel">
                <lyu:SimpleStackPanel Orientation="Horizontal" Spacing="12">
                    <Button
                        Width="100"
                        Height="30"
                        Content="1" />
                    <Button
                        Width="100"
                        Height="30"
                        Content="2" />
                    <Button
                        Width="100"
                        Height="30"
                        Content="3" />
                </lyu:SimpleStackPanel>
            </TabItem>

            <TabItem Header="datagrid  多选绑定">
                <Grid>
                    <DataGrid
                        lyu:DataGridRowNumberBehavior.HeaderText="序号"
                        lyu:DataGridRowNumberBehavior.IsEnabled="True"
                        lyu:DataGridSelectedItemsBehavior.SelectedItems="{Binding SelectedData}"
                        CanUserAddRows="False"
                        ItemsSource="{Binding Datas}"
                        SelectionMode="Extended"
                        SelectionUnit="FullRow">
                    </DataGrid>

                    <TextBlock VerticalAlignment="Bottom" Text="{Binding TestText}" />
                </Grid>

            </TabItem>

            <TabItem Header="可选择文本框">
                <lyu:SimpleStackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Orientation="Vertical"
                    Spacing="24">
                    <lyu:SelectableTextBlock Text="1274626491749384" />
                    <TextBox />
                </lyu:SimpleStackPanel>
            </TabItem>

            <TabItem Header="Grid辅助">
                <Grid lyu:GridHelper.ColumnDefinitions="*,*" lyu:GridHelper.RowDefinitions="Auto,*">
                    <Border
                        Grid.Row="0"
                        Grid.ColumnSpan="2"
                        Height="80"
                        Background="Yellow"
                        Opacity="0.4" />

                    <Border
                        Grid.Row="1"
                        Grid.Column="0"
                        Background="Red"
                        Opacity="0.4" />

                    <Border
                        Grid.Row="1"
                        Grid.Column="1"
                        Background="Blue"
                        Opacity="0.4" />
                </Grid>
            </TabItem>

            <TabItem Header="全屏功能">
                <Grid RowDefinitions="*,Auto">
                    <lyu:SimpleStackPanel
                        Grid.Row="0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Orientation="Vertical"
                        Spacing="20">
                        <TextBlock
                            FontSize="16"
                            FontWeight="Bold"
                            Text="全屏功能演示" />
                        <TextBlock Text="按 F11 键切换全屏模式" />
                        <TextBlock Text="或点击下面的按钮：" />
                        <Button
                            Width="200"
                            Height="40"
                            Click="ToggleFullScreenButton_Click"
                            Content="切换全屏" />
                        <TextBlock
                            Margin="0,20,0,0"
                            Text="说明："
                            TextWrapping="Wrap" />
                        <TextBlock Text="• 全屏模式会隐藏标题栏和任务栏" TextWrapping="Wrap" />
                        <TextBlock Text="• 窗口会占据整个屏幕" TextWrapping="Wrap" />
                        <TextBlock Text="• 退出全屏后会恢复原来的窗口状态" TextWrapping="Wrap" />
                    </lyu:SimpleStackPanel>

                    <Border
                        Grid.Row="1"
                        Height="30"
                        Background="Red"
                        CornerRadius="15">

                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="过渡动画控件">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <lyu:SimpleStackPanel
                        Margin="20"
                        Orientation="Vertical"
                        Spacing="30">

                        <!--  演示区域  -->
                        <GroupBox Header="动画演示区">
                            <Border
                                Width="400"
                                Height="300"
                                Background="#F5F5F5"
                                BorderBrush="#E0E0E0"
                                BorderThickness="1"
                                CornerRadius="8">
                                <lyu:TransitioningContentControl
                                    x:Name="TransitionControl"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                                    <Border
                                        Padding="40,30"
                                        Background="White"
                                        BorderBrush="#2196F3"
                                        BorderThickness="2"
                                        CornerRadius="8">
                                        <lyu:SimpleStackPanel Orientation="Vertical" Spacing="10">
                                            <TextBlock
                                                FontSize="24"
                                                FontWeight="Bold"
                                                Foreground="#2196F3"
                                                Text="Hello World" />
                                            <TextBlock
                                                FontSize="14"
                                                Foreground="#757575"
                                                Text="这是一个过渡动画控件演示" />
                                        </lyu:SimpleStackPanel>
                                    </Border>
                                </lyu:TransitioningContentControl>
                            </Border>
                        </GroupBox>

                        <!--  动画模式选择  -->
                        <GroupBox Header="选择动画模式">
                            <lyu:SimpleStackPanel Orientation="Vertical" Spacing="10">
                                <lyu:SimpleStackPanel Orientation="Horizontal" Spacing="10">
                                    <Button
                                        Width="150"
                                        Height="35"
                                        Click="SetTransitionMode_Click"
                                        Content="Right2Left"
                                        Tag="Right2Left" />
                                    <Button
                                        Width="150"
                                        Height="35"
                                        Click="SetTransitionMode_Click"
                                        Content="Left2Right"
                                        Tag="Left2Right" />
                                    <Button
                                        Width="150"
                                        Height="35"
                                        Click="SetTransitionMode_Click"
                                        Content="Bottom2Top"
                                        Tag="Bottom2Top" />
                                    <Button
                                        Width="150"
                                        Height="35"
                                        Click="SetTransitionMode_Click"
                                        Content="Top2Bottom"
                                        Tag="Top2Bottom" />
                                </lyu:SimpleStackPanel>
                                <lyu:SimpleStackPanel Orientation="Horizontal" Spacing="10">
                                    <Button
                                        Width="150"
                                        Height="35"
                                        Click="SetTransitionMode_Click"
                                        Content="Right2Left + Fade"
                                        Tag="Right2LeftWithFade" />
                                    <Button
                                        Width="150"
                                        Height="35"
                                        Click="SetTransitionMode_Click"
                                        Content="Left2Right + Fade"
                                        Tag="Left2RightWithFade" />
                                    <Button
                                        Width="150"
                                        Height="35"
                                        Click="SetTransitionMode_Click"
                                        Content="Bottom2Top + Fade"
                                        Tag="Bottom2TopWithFade" />
                                    <Button
                                        Width="150"
                                        Height="35"
                                        Click="SetTransitionMode_Click"
                                        Content="Top2Bottom + Fade"
                                        Tag="Top2BottomWithFade" />
                                </lyu:SimpleStackPanel>
                                <Button
                                    Width="150"
                                    Height="35"
                                    Click="SetTransitionMode_Click"
                                    Content="Fade Only"
                                    Tag="Fade" />
                            </lyu:SimpleStackPanel>
                        </GroupBox>

                        <!--  内容切换测试  -->
                        <GroupBox Header="切换内容测试">
                            <lyu:SimpleStackPanel Orientation="Horizontal" Spacing="10">
                                <Button
                                    Width="150"
                                    Height="35"
                                    Click="ChangeContent_Click"
                                    Content="切换到内容 1"
                                    Tag="1" />
                                <Button
                                    Width="150"
                                    Height="35"
                                    Click="ChangeContent_Click"
                                    Content="切换到内容 2"
                                    Tag="2" />
                                <Button
                                    Width="150"
                                    Height="35"
                                    Click="ChangeContent_Click"
                                    Content="切换到内容 3"
                                    Tag="3" />
                            </lyu:SimpleStackPanel>
                        </GroupBox>

                        <!--  说明  -->
                        <GroupBox Header="使用说明">
                            <lyu:SimpleStackPanel Orientation="Vertical" Spacing="8">
                                <TextBlock Text="• 选择不同的动画模式，然后切换内容查看效果" />
                                <TextBlock Text="• Right2Left: 从右向左滑入" />
                                <TextBlock Text="• Left2Right: 从左向右滑入" />
                                <TextBlock Text="• Bottom2Top: 从下向上滑入" />
                                <TextBlock Text="• Top2Bottom: 从上向下滑入" />
                                <TextBlock Text="• WithFade: 带淡入效果" />
                                <TextBlock Text="• Fade: 仅淡入效果" />
                            </lyu:SimpleStackPanel>
                        </GroupBox>
                    </lyu:SimpleStackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="通知">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <lyu:SimpleStackPanel
                        Margin="20"
                        Orientation="Vertical"
                        Spacing="20">

                        <!--  右上角通知  -->
                        <GroupBox Header="右上角通知 (TopRight)">
                            <lyu:SimpleStackPanel Orientation="Vertical" Spacing="10">
                                <Button
                                    Width="200"
                                    Height="35"
                                    Click="ShowTopRightInfo_Click"
                                    Content="信息通知 (3秒)" />
                                <Button
                                    Width="200"
                                    Height="35"
                                    Click="ShowTopRightSuccess_Click"
                                    Content="成功通知 (3秒)" />
                                <Button
                                    Width="200"
                                    Height="35"
                                    Click="ShowTopRightWarning_Click"
                                    Content="警告通知 (5秒)" />
                                <Button
                                    Width="200"
                                    Height="35"
                                    Click="ShowTopRightError_Click"
                                    Content="错误通知 (10秒)" />
                            </lyu:SimpleStackPanel>
                        </GroupBox>

                        <!--  右下角通知  -->
                        <GroupBox Header="右下角通知 (BottomRight)">
                            <lyu:SimpleStackPanel Orientation="Vertical" Spacing="10">
                                <Button
                                    Width="200"
                                    Height="35"
                                    Click="ShowBottomRightInfo_Click"
                                    Content="信息通知 (3秒)" />
                                <Button
                                    Width="200"
                                    Height="35"
                                    Click="ShowBottomRightSuccess_Click"
                                    Content="成功通知 (3秒)" />
                                <Button
                                    Width="200"
                                    Height="35"
                                    Click="ShowBottomRightWarning_Click"
                                    Content="警告通知 (5秒)" />
                                <Button
                                    Width="200"
                                    Height="35"
                                    Click="ShowBottomRightError_Click"
                                    Content="错误通知 (10秒)" />
                            </lyu:SimpleStackPanel>
                        </GroupBox>

                        <!--  中上通知  -->
                        <GroupBox Header="中上通知 (TopCenter)">
                            <lyu:SimpleStackPanel Orientation="Vertical" Spacing="10">
                                <Button
                                    Width="200"
                                    Height="35"
                                    Click="ShowTopCenterInfo_Click"
                                    Content="信息通知 (3秒)" />
                                <Button
                                    Width="200"
                                    Height="35"
                                    Click="ShowTopCenterSuccess_Click"
                                    Content="成功通知 (3秒)" />
                                <Button
                                    Width="200"
                                    Height="35"
                                    Click="ShowTopCenterWarning_Click"
                                    Content="警告通知 (5秒)" />
                                <Button
                                    Width="200"
                                    Height="35"
                                    Click="ShowTopCenterError_Click"
                                    Content="错误通知 (10秒)" />
                            </lyu:SimpleStackPanel>
                        </GroupBox>

                        <!--  中下通知  -->
                        <GroupBox Header="中下通知 (BottomCenter)">
                            <lyu:SimpleStackPanel Orientation="Vertical" Spacing="10">
                                <Button
                                    Width="200"
                                    Height="35"
                                    Click="ShowBottomCenterInfo_Click"
                                    Content="信息通知 (3秒)" />
                                <Button
                                    Width="200"
                                    Height="35"
                                    Click="ShowBottomCenterSuccess_Click"
                                    Content="成功通知 (3秒)" />
                                <Button
                                    Width="200"
                                    Height="35"
                                    Click="ShowBottomCenterWarning_Click"
                                    Content="警告通知 (5秒)" />
                                <Button
                                    Width="200"
                                    Height="35"
                                    Click="ShowBottomCenterError_Click"
                                    Content="错误通知 (10秒)" />
                            </lyu:SimpleStackPanel>
                        </GroupBox>

                        <!--  批量测试  -->
                        <GroupBox Header="批量测试">
                            <lyu:SimpleStackPanel Orientation="Vertical" Spacing="10">
                                <Button
                                    Width="200"
                                    Height="35"
                                    Click="ShowMultipleNotifications_Click"
                                    Content="显示多个通知 (测试最多5个)" />
                                <Button
                                    Width="200"
                                    Height="35"
                                    Click="ShowAllPositions_Click"
                                    Content="所有位置同时显示" />
                            </lyu:SimpleStackPanel>
                        </GroupBox>
                    </lyu:SimpleStackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Busy蒙版">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <lyu:SimpleStackPanel
                        Margin="20"
                        Orientation="Vertical"
                        Spacing="16">
                        <lyu:SimpleStackPanel Orientation="Horizontal" Spacing="12">
                            <Button
                                Width="180"
                                Height="35"
                                Click="ShowDefaultBusy_Click"
                                Content="Default Busy" />
                            <Button
                                Width="180"
                                Height="35"
                                Click="ShowTaskBusy_Click"
                                Content="长时任务 Busy(超时cancel)" />
                            <Button
                                Width="180"
                                Height="35"
                                Click="ShowTaskBusywithoutTimeout_Click"
                                Content="长时任务 Busy(无超时)" />
                            <Button
                                Width="180"
                                Height="35"
                                Click="ShowCustomBusy_Click"
                                Content="自定义 Busy" />
                        </lyu:SimpleStackPanel>
                    </lyu:SimpleStackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="抽屉">
                <lyu:DrawersHost
                    x:Name="DrawerDemoHost"
                    Margin="16"
                    OverlayCloseBehavior="CloseTopMost"
                    OverlayMode="WhenAnyOpen">
                    <lyu:DrawersHost.MainContent>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <lyu:SimpleStackPanel Orientation="Vertical" Spacing="16">
                                <Border
                                    Padding="16"
                                    Background="#09FFFFFF"
                                    BorderBrush="#20000000"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                    <lyu:SimpleStackPanel Orientation="Vertical" Spacing="12">
                                        <TextBlock
                                            FontSize="16"
                                            FontWeight="SemiBold"
                                            Text="Drawer 控件演示（支持主题联动）" />
                                        <WrapPanel>
                                            <Button
                                                Width="120"
                                                Margin="0,0,8,8"
                                                Click="OpenDemoDrawer_Click"
                                                Content="打开左抽屉"
                                                Tag="Left" />
                                            <Button
                                                Width="120"
                                                Margin="0,0,8,8"
                                                Click="OpenDemoDrawer_Click"
                                                Content="打开右抽屉"
                                                Tag="Right" />
                                            <Button
                                                Width="120"
                                                Margin="0,0,8,8"
                                                Click="OpenDemoDrawer_Click"
                                                Content="打开上抽屉"
                                                Tag="Top" />
                                            <Button
                                                Width="120"
                                                Margin="0,0,8,8"
                                                Click="OpenDemoDrawer_Click"
                                                Content="打开下抽屉"
                                                Tag="Bottom" />
                                            <Button
                                                Width="120"
                                                Margin="0,0,8,8"
                                                Click="CloseAllDemoDrawers_Click"
                                                Content="关闭全部" />
                                        </WrapPanel>

                                        <WrapPanel>
                                            <CheckBox
                                                x:Name="DrawerPinCheckBox"
                                                Margin="0,0,14,8"
                                                Checked="DrawerOptionChanged"
                                                Content="固定抽屉（禁止外部点击关闭）"
                                                Unchecked="DrawerOptionChanged" />
                                            <CheckBox
                                                x:Name="DrawerAnimateCheckBox"
                                                Margin="0,0,14,8"
                                                Checked="DrawerOptionChanged"
                                                Content="启用动画"
                                                IsChecked="True"
                                                Unchecked="DrawerOptionChanged" />
                                            <CheckBox
                                                x:Name="DrawerAnimateOpacityCheckBox"
                                                Margin="0,0,14,8"
                                                Checked="DrawerOptionChanged"
                                                Content="透明度动画"
                                                IsChecked="True"
                                                Unchecked="DrawerOptionChanged" />
                                            <CheckBox
                                                x:Name="DrawerCloseOnOverlayCheckBox"
                                                Margin="0,0,14,8"
                                                Checked="DrawerOptionChanged"
                                                Content="允许遮罩点击关闭"
                                                IsChecked="True"
                                                Unchecked="DrawerOptionChanged" />
                                            <CheckBox
                                                x:Name="DrawerCloseOnEscapeCheckBox"
                                                Margin="0,0,14,8"
                                                Checked="DrawerOptionChanged"
                                                Content="允许 ESC 关闭"
                                                IsChecked="True"
                                                Unchecked="DrawerOptionChanged" />
                                        </WrapPanel>

                                        <WrapPanel VerticalAlignment="Center">
                                            <TextBlock
                                                Margin="0,0,8,8"
                                                VerticalAlignment="Center"
                                                Text="主题模式：" />
                                            <ComboBox
                                                x:Name="DrawerThemeModeComboBox"
                                                Width="130"
                                                Margin="0,0,20,8"
                                                SelectedIndex="0"
                                                SelectionChanged="DrawerThemeModeComboBox_SelectionChanged">
                                                <ComboBoxItem Tag="Adapt">Adapt</ComboBoxItem>
                                                <ComboBoxItem Tag="Light">Light</ComboBoxItem>
                                                <ComboBoxItem Tag="Dark">Dark</ComboBoxItem>
                                                <ComboBoxItem Tag="Inverse">Inverse</ComboBoxItem>
                                            </ComboBox>

                                            <TextBlock
                                                Margin="0,0,8,8"
                                                VerticalAlignment="Center"
                                                Text="遮罩模式：" />
                                            <ComboBox
                                                x:Name="DrawerOverlayModeComboBox"
                                                Width="140"
                                                Margin="0,0,20,8"
                                                SelectedIndex="0"
                                                SelectionChanged="DrawerOverlayModeComboBox_SelectionChanged">
                                                <ComboBoxItem Tag="WhenAnyOpen">任意打开即遮罩</ComboBoxItem>
                                                <ComboBoxItem Tag="ModalOnly">仅 Modal 抽屉遮罩</ComboBoxItem>
                                            </ComboBox>

                                            <TextBlock
                                                Margin="0,0,8,8"
                                                VerticalAlignment="Center"
                                                Text="遮罩关闭策略：" />
                                            <ComboBox
                                                x:Name="DrawerOverlayCloseBehaviorComboBox"
                                                Width="150"
                                                Margin="0,0,20,8"
                                                SelectedIndex="0"
                                                SelectionChanged="DrawerOverlayCloseBehaviorComboBox_SelectionChanged">
                                                <ComboBoxItem Tag="CloseTopMost">只关顶层</ComboBoxItem>
                                                <ComboBoxItem Tag="CloseAllClosable">关闭全部可关闭抽屉</ComboBoxItem>
                                            </ComboBox>
                                        </WrapPanel>

                                        <Grid Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="220" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="120" />
                                                <ColumnDefinition Width="50" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock
                                                Grid.Column="0"
                                                Margin="0,0,8,0"
                                                VerticalAlignment="Center"
                                                Text="自动关闭(秒)：" />
                                            <Slider
                                                x:Name="DrawerAutoCloseSlider"
                                                Grid.Column="1"
                                                IsSnapToTickEnabled="True"
                                                Maximum="10"
                                                TickFrequency="1"
                                                ValueChanged="DrawerAutoCloseSlider_ValueChanged" />
                                            <TextBlock
                                                Grid.Column="2"
                                                Margin="12,0,8,0"
                                                VerticalAlignment="Center"
                                                Text="隐藏偏移：" />
                                            <Slider
                                                x:Name="DrawerHiddenOffsetSlider"
                                                Grid.Column="3"
                                                IsSnapToTickEnabled="True"
                                                Maximum="120"
                                                TickFrequency="10"
                                                ValueChanged="DrawerHiddenOffsetSlider_ValueChanged" />
                                            <TextBlock
                                                x:Name="DrawerAutoCloseValueText"
                                                Grid.Column="4"
                                                VerticalAlignment="Center"
                                                Text="0s" />
                                        </Grid>
                                    </lyu:SimpleStackPanel>
                                </Border>

                                <Border
                                    Height="440"
                                    Padding="16"
                                    Background="#08FFFFFF"
                                    BorderBrush="#20000000"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                    <lyu:SimpleStackPanel Orientation="Vertical" Spacing="8">
                                        <TextBlock
                                            FontSize="15"
                                            FontWeight="SemiBold"
                                            Text="主内容区域" />
                                        <TextBlock Text="你可以在这个区域继续交互，打开不同方向抽屉，并尝试切换窗口主题（浅色/深色/跟随系统）。" TextWrapping="Wrap" />
                                        <TextBlock Text="当前设计点：" />
                                        <TextBlock Text="1. 支持四方向打开，默认带位移动画和透明度动画。" />
                                        <TextBlock Text="2. 支持遮罩策略、ESC 关闭、外部点击关闭、固定抽屉等行为配置。" />
                                        <TextBlock Text="3. 支持抽屉主题模式 Adapt/Light/Dark/Inverse，并跟随窗口主题切换。" />
                                    </lyu:SimpleStackPanel>
                                </Border>
                            </lyu:SimpleStackPanel>
                        </ScrollViewer>
                    </lyu:DrawersHost.MainContent>

                    <lyu:Drawer
                        x:Name="LeftDemoDrawer"
                        Width="340"
                        CornerRadius="0,12,12,0"
                        Header="左侧抽屉"
                        Position="Left">
                        <lyu:SimpleStackPanel Orientation="Vertical" Spacing="10">
                            <TextBlock
                                FontSize="15"
                                FontWeight="SemiBold"
                                Text="筛选与导航" />
                            <TextBlock Text="适合放菜单、筛选器、目录树等内容。" TextWrapping="Wrap" />
                            <CheckBox Content="启用高级筛选" />
                            <CheckBox Content="仅显示已完成项" />
                            <Button
                                Click="CloseDemoDrawer_Click"
                                Content="关闭当前抽屉"
                                Tag="Left" />
                        </lyu:SimpleStackPanel>
                    </lyu:Drawer>

                    <lyu:Drawer
                        x:Name="RightDemoDrawer"
                        Width="380"
                        CornerRadius="12,0,0,12"
                        Header="右侧抽屉"
                        Position="Right">
                        <lyu:SimpleStackPanel Orientation="Vertical" Spacing="10">
                            <TextBlock
                                FontSize="15"
                                FontWeight="SemiBold"
                                Text="详情面板" />
