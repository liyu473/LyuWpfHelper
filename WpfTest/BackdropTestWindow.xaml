<Window
    x:Class="WpfTest.BackdropTestWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:lyu="http://schemas.lyuwpfhelper.com/winfx/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    Title="Backdrop 测试窗口"
    Width="800"
    Height="600"
    lyu:WindowBackdropHelper.Backdrop="Acrylic"
    ui:WindowHelper.UseModernWindowStyle="True"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <lyu:DrawersHost Grid.RowSpan="2">
            <lyu:Drawer
                x:Name="TestDrawer"
                CloseOnOverlayClick="True"
                ExternalCloseButton="Left"
                IsModal="True"
                IsPinned="False"
                ShowOverlay="True" />
        </lyu:DrawersHost>

        <!--  标题栏区域  -->
        <Border
            Grid.Row="0"
            Height="40"
            BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="False">
                <TextBlock
                    Margin="16,0,0,0"
                    VerticalAlignment="Center"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Foreground="#223046"
                    Text="Backdrop 效果测试" />

                <StackPanel
                    Margin="16,0,0,0"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <TextBlock VerticalAlignment="Center" Text="主题" />
                    <ComboBox
                        x:Name="BackdropThemeComboBox"
                        Width="100"
                        Margin="8,0,0,0"
                        SelectedIndex="0"
                        SelectionChanged="BackdropThemeComboBox_SelectionChanged">
                        <ComboBoxItem Tag="Light">浅色</ComboBoxItem>
                        <ComboBoxItem Tag="Dark">深色</ComboBoxItem>
                        <ComboBoxItem Tag="FollowSystem">跟随系统</ComboBoxItem>
                    </ComboBox>
                    <Button
                        Width="100"
                        Height="28"
                        Margin="8,0,0,0"
                        Click="SetDefault_Click"
                        Content="Default" />
                    <Button
                        Width="100"
                        Height="28"
                        Margin="8,0,0,0"
                        Click="SetAcrylic_Click"
                        Content="Acrylic" />
                    <Button
                        Width="100"
                        Height="28"
                        Margin="8,0,0,0"
                        Click="SetMica_Click"
                        Content="Mica" />
                    <Button
                        Width="100"
                        Height="28"
                        Margin="8,0,0,0"
                        Click="SetTabbed_Click"
                        Content="Tabbed" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!--  内容区域  -->
        <Grid Grid.Row="1" Margin="20">
            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Orientation="Vertical">
                <TextBlock
                    FontSize="24"
                    FontWeight="Bold"
                    Text="Backdrop 效果测试"
                    TextAlignment="Center" />
                <TextBlock
                    Margin="0,20,0,0"
                    FontSize="14"
                    Foreground="#666666"
                    Text="点击上方按钮切换不同的 Backdrop 效果"
                    TextAlignment="Center" />
                <TextBlock
                    Margin="0,10,0,0"
                    FontSize="12"
                    Foreground="#999999"
                    Text="需要 Windows 11 及以上版本才能看到效果"
                    TextAlignment="Center" />

                <Border
                    Margin="0,40,0,0"
                    Padding="20"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Orientation="Vertical">
                        <TextBlock
                            FontSize="16"
                            FontWeight="SemiBold"
                            Text="当前效果说明：" />
                        <TextBlock
                            x:Name="DescriptionText"
                            Margin="0,10,0,0"
                            FontSize="14"
                            Text="Default - 白色背景（无特效）"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <lyu:SimpleStackPanel
                    HorizontalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="12">
                    <Button Click="Drawer_Click" Content="抽屉" />
                    <Button Click="Busy_Click" Content="Busy" />
                    <Button Click="Noticification_Click" Content="通知" />
                </lyu:SimpleStackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
